{
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"]
  },
  "include": [
    "config/**/*.ts",
    "vite.config.ts",
    "vitest.config.mjs",
    "eslint.config.ts",
    "playwright.config.ts",
    "eslint/**/*.ts"
  ]
}
